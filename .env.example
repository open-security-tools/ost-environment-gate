# Stack name for AWS CloudFormation
STACK_NAME=ost-environment-gate

# Path to the policy file (compacted with jq during deploy)
POLICY_FILE=policy.json

# GitHub App ID (numeric App ID or Client ID both work)
APP_ID=your-app-id

# SSM parameter name for the App ID
APP_ID_PARAMETER=/ost/app-id

# Secrets Manager secret name for the private key
APP_PRIVATE_KEY_SECRET_NAME=ost/app-private-key

# Path to the GitHub App private key PEM file
APP_PRIVATE_KEY_FILE=.secrets/github-app-private-key.pem

# GitHub webhook secret (must match the secret in the GitHub App settings)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# SSM parameter name for the webhook secret
WEBHOOK_SECRET_PARAMETER=/ost/webhook-secret
